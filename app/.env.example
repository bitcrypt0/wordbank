# WORDBANK dApp — environment template (PUBLIC; copy to .env.local for local dev).
# .env.local is gitignored. NEVER put an Alchemy/Infura/keyed RPC URL in ANY
# NEXT_PUBLIC_* var: those are inlined into the browser bundle and shipped to
# every visitor, so any embedded key becomes public the moment the site is live.

# --- Network selection (REQUIRED for non-mainnet) ---
# 1 = Ethereum mainnet / mainnet-fork (default if unset) · 11155111 = Sepolia
NEXT_PUBLIC_CHAIN_ID=1

# --- Read RPC (OPTIONAL) ---
# How chain reads resolve, in order:
#   1. Connected wallet  -> reads ride the VISITOR'S own node (EIP-1193 provider).
#   2. NEXT_PUBLIC_RPC_URL (this var), IF set -> used before a wallet connects.
#   3. Public fallback    -> a built-in viem fallback() of KEYLESS endpoints that
#      can run the V4 swap quoter (mainnet: publicnode -> drpc -> 1rpc). NOT viem's
#      cloudflare default, which fails the quoter eth_call (would show a 0 quote).
#
# Leave this UNSET to use the wallet + keyless public fallback (recommended for a
# public deploy — swap quotes work without it). If you set it, it MUST be a
# PUBLIC / keyless endpoint; it just front-ranks the pre-connect fallback.
#   Pin example (optional):    NEXT_PUBLIC_RPC_URL=https://ethereum-rpc.publicnode.com
#   Local Anvil fork example:  NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8545
#   Sepolia rehearsal example: NEXT_PUBLIC_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# NEXT_PUBLIC_RPC_URL=

{
  "name": "wordbank-deploy",
  "version": "1.0.0",
  "private": true,
  "description": "WORDBANK deployment orchestration (Hardhat consumes Foundry out/ artifacts; Foundry is the compiler of record)",
  "scripts": {
    "deploy:protocol": "hardhat run scripts/01-deploy-protocol.ts",
    "upload:renderer": "hardhat run scripts/01b-upload-renderer.ts",
    "upload:slots": "hardhat run scripts/01c-upload-slots.ts",
    "verify:content": "hardhat run scripts/verify-content.ts",
    "seed-and-launch": "hardhat run scripts/02-seed-and-launch.ts",
    "sync-registry": "hardhat run scripts/02b-sync-registry.ts",
    "lock-liquidity": "hardhat run scripts/04-lock-liquidity.ts",
    "enable-trading": "hardhat run scripts/05-enable-trading.ts",
    "add-liquidity": "hardhat run scripts/06-add-liquidity.ts",
    "remove-liquidity": "hardhat run scripts/07-remove-liquidity.ts",
    "seal-and-renounce": "hardhat run scripts/03-seal-and-renounce.ts",
    "snapshot:migration": "hardhat run scripts/snapshot-merkle.ts",
    "v2:deploy": "hardhat run scripts/v2-01-deploy.ts",
    "v2:seed-and-launch": "hardhat run scripts/v2-02-seed-and-launch.ts",
    "v2:enable-trading": "hardhat run scripts/v2-03-enable-trading.ts",
    "verify-commands": "ts-node scripts/verify-commands.ts --print",
    "verify:mainnet": "ts-node scripts/verify-commands.ts --network mainnet",
    "verify:sepolia": "ts-node scripts/verify-commands.ts --network sepolia",
    "test:normalize": "ts-node scripts/normalize.test.ts",
    "test:verify": "ts-node scripts/verify.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@openzeppelin/merkle-tree": "^1.0.7",
    "@types/node": "^22.10.0",
    "dotenv": "^16.4.7",
    "ethers": "^6.13.4",
    "hardhat": "^2.22.17",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}

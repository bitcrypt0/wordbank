# ── signer ──────────────────────────────────────────────────────────────────────────────
PRIVATE_KEY=                  # the protocol admin key (broadcasts every phase)

# ── networks ────────────────────────────────────────────────────────────────────────────
MAINNET_RPC_URL=              # your mainnet RPC URL (e.g. Alchemy/Infura) — set in deploy/.env, NEVER commit a real key

SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
ANVIL_RPC_URL=http://127.0.0.1:8545
ETHERSCAN_API_KEY=            # for one-command verification: `npm run verify:mainnet`.
                             # Get a FREE key at https://etherscan.io/myapikey — ONE key works
                             # for every chain (mainnet + Sepolia, via Etherscan v2 multichain).

# ── phase 1 (01-deploy-protocol) ────────────────────────────────────────────────────────
ADMIN=                        # protocol admin address (usually the signer address)
POOL_MANAGER=                 # canonical Uniswap V4 PoolManager on the target chain
POSITION_MANAGER=             # canonical Uniswap V4 PositionManager on the target chain
# WETH MUST be the chain's canonical WETH9 — the deploy script asserts this (RS-2). Use:
#   mainnet (1):           0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2
#   Sepolia (11155111):    0xfFf9976782d46CC05630D1f6eBAb18b2324d6B14
#   mainnet-fork Anvil:    0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2 (fork keeps chainId 1)
WETH=0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2
# WETH_OVERRIDE=             # ONLY for a bare local Anvil (unknown chainId); set = your test WETH9
# WORDBANK_ADDRESS=          # resume/recovery ONLY: reuse an already-live WordBank instead of
#                            # redeploying (see RUNBOOK "if something goes wrong mid-Phase 1")
# LP_FEE=3000                 # pool LP fee in pips (0.30%)
# TICK_SPACING=60

# ── phase 1.5 (01b-upload-renderer, 01c-upload-slots) ───────────────────────────────────
# Uploads Agent 2's on-chain content from assets/ — no per-run config required (it reads the
# repo's asset files and addresses/<network>.json). Broadcaster MUST be the ADMIN/owner key.
# SLOT_BATCH=50               # word slots per setWordSlots tx (default 50; ~200 txs total)

# ── phase 2a (02-seed-and-launch) — seed the pool only; trading OFF, position UNlocked ──────
SQRT_PRICE_X96=               # launch price: floor(sqrt(WORD-per-ETH) * 2^96) — see RUNBOOK
ETH_LIQUIDITY=                # ETH side of the seed, in wei
# WORD_LIQUIDITY=1000000000000000000000000   # default: the full 1M allotment
# POSITION_TOKEN_ID=          # resume/recovery ONLY: adopt this existing position, skip minting
                              # (see RUNBOOK "if something goes wrong mid-Phase 2")

# ── phase 2b (04-lock-liquidity) — lock the seeded position; run when ready ──────────────────
# LOCK_DURATION_DAYS=366      # default 366 — a 1-day buffer over the 365-day MIN_LOCK_DURATION
# POSITION_TOKEN_ID=          # default: the tokenId 02-seed-and-launch recorded. Pass to lock a
                              # specific position (recovery). The forge mirror ALWAYS needs it.

# ── phase 2c (05-enable-trading) — flip trading live; run when ready ─────────────────────────
#   (no extra env — reuses the addresses + LP_FEE/TICK_SPACING from phase 1/2a)

# ── temporary depth for buybacks (06-add-liquidity / 07-remove-liquidity) ────────────────────
#   Use ONLY if executeBuyback reverts SlippageExceeded (pool too thin). Add → run buybacks →
#   remove. The extra position is yours and is NOT locked; the locked seed position is untouched.
#   See RUNBOOK "If buybacks won't run: temporarily add liquidity".
# ETH_LIQUIDITY_ADD=            # 06: ETH to add, in wei
# WORD_LIQUIDITY_ADD=          # 06: WORD to add, in wei (you source this — e.g. collected LP fees)
# POSITION_TOKEN_ID=          # 07 forge mirror ONLY: the extra position id 06 printed
# LOCKED_POSITION_TOKEN_ID=   # 07 forge mirror ONLY: the locked seed id (refuse-if-equal guard)

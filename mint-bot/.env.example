# Copy to .env (which is gitignored). Nothing here is required to run — the bot
# takes the RPC URL, chain ID, contract address, and wallet keys in the UI.
# This is a KEY-HANDLING tool: KEEP REAL PRIVATE KEYS OUT OF GIT (and out of
# this file). mint-wallets/, wallets.json, and wallets-*.json are gitignored.
NODE_ENV=development
PORT=3000

# Optional convenience reference values (NOT auto-loaded by the UI):
# Mainnet WordBank address:
#   WORDBANK_ADDRESS=0x63a92C4E448847c906b7657C20630650e6bA1218
# WORDBANK_CHAIN_ID=1
# WORDBANK_RPC_URL=https://...   (paste a mainnet RPC in the UI)
# (Never put a funded private key in a committed file.)

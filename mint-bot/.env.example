# Copy to .env (which is gitignored). Nothing here is required to run — the bot
# takes the RPC, contract address, and primary key in the UI — but you may set
# defaults the dev server reads if you wire them in. KEEP REAL KEYS OUT OF GIT.
NODE_ENV=development
PORT=3000

# Optional convenience defaults (NOT auto-loaded by the UI; for your reference):
# WORDBANK_RPC_URL=http://127.0.0.1:8545
# WORDBANK_ADDRESS=0x...
# (Never put a funded private key in a committed file.)
